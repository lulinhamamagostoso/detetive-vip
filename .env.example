# ── PayEvo (Gateway PIX) ─────────────────────────────────────────────
# Obrigatório — sem isso, pagamentos não funcionam
PAYEVO_SECRET_KEY=sua_chave_secreta_aqui

# Recomendado — valida assinatura dos webhooks (segurança contra fraude)
PAYEVO_WEBHOOK_SECRET=seu_webhook_secret_aqui

# ── Formspree (Recebimento de leads por email) ──────────────────────
# Opcional — já tem fallback "xzdkqqkp" no código
NEXT_PUBLIC_FORMSPREE_ID=seu_formspree_id_aqui

# ── URL base do site ────────────────────────────────────────────────
# Opcional — já tem fallback "https://www.detetive.vip"
NEXT_PUBLIC_BASE_URL=https://www.detetive.vip
